---
import BaseLayout from './BaseLayout.astro';
import TypeBadge from '../components/TypeBadge.astro';
import TagList from '../components/TagList.astro';
import SourcesList from '../components/SourcesList.astro';
import { artForTags } from '../lib/topicArt';

interface Props {
  title: string;
  summary: string;
  type: 'evergreen' | 'curated' | 'editorial';
  tags: string[];
  sources?: string[];
  first_published: Date;
  last_updated?: Date;
  external_url?: string;
  /** Optional photo hero (replaces the illustration band) + its attribution */
  image?: string;
  imageAlt?: string;
  imageCreditName?: string;
  imageCreditUrl?: string;
  imageSourceUrl?: string;
  /** Raw markdown body, used for reading time */
  body?: string;
}

const {
  title,
  summary,
  type,
  tags,
  sources = [],
  first_published,
  last_updated,
  external_url,
  image,
  imageAlt = '',
  imageCreditName,
  imageCreditUrl,
  imageSourceUrl,
  body = '',
} = Astro.props;

const formattedDate = first_published.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const updatedDate = last_updated?.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const backLinks: Record<string, { href: string; label: string }> = {
  evergreen: { href: '/articles', label: 'All articles' },
  curated: { href: '/curated', label: 'All curated links' },
  editorial: { href: '/editorial', label: 'All editorials' },
};

const art = artForTags(tags);
const readingMinutes = Math.max(1, Math.round(body.split(/\s+/).length / 220));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: summary,
  datePublished: first_published.toISOString(),
  dateModified: (last_updated ?? first_published).toISOString(),
  author: { '@type': 'Organization', name: 'YourKids Editorial Team' },
  publisher: { '@type': 'Organization', name: 'YourKids', url: Astro.site?.toString() },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
};
---

<BaseLayout
  title={title}
  description={summary}
  ogType="article"
  publishedTime={first_published}
  modifiedTime={last_updated}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <article data-pagefind-body>
    <header class="content-header" style={`--accent: ${art.accent}; --accent-tint: ${art.tint};`}>
      {image ? (
        <figure class="content-header__photo">
          <img src={image} alt={imageAlt} loading="eager" decoding="async" />
          {imageCreditName && (
            <figcaption class="content-header__credit">
              Photo by{' '}
              <a href={imageCreditUrl} target="_blank" rel="noopener noreferrer">{imageCreditName}</a>
              {' '}on{' '}
              <a href={imageSourceUrl ?? 'https://unsplash.com'} target="_blank" rel="noopener noreferrer">Unsplash</a>
            </figcaption>
          )}
        </figure>
      ) : (
        <div class="content-header__band" aria-hidden="true">
          <div class="content-header__art" set:html={art.markup} />
        </div>
      )}
      {type === 'editorial' && (
        <div class="editorial-banner">Editor's Perspective</div>
      )}
      <div class="content-header__meta">
        <TypeBadge type={type} />
        <time datetime={first_published.toISOString()}>{formattedDate}</time>
        {updatedDate && <span>&middot; Updated {updatedDate}</span>}
        {body && <span>&middot; {readingMinutes} min read</span>}
      </div>
      <h1>{title}</h1>
      <p class="content-header__summary">{summary}</p>
      {type === 'curated' && external_url && (
        <a href={external_url} class="curated-cta" target="_blank" rel="noopener noreferrer">
          Read at source &rarr;
        </a>
      )}
      <div class="content-header__tags">
        <TagList tags={tags} />
      </div>
    </header>

    <div class="content-body">
      <slot />
    </div>

    {sources.length > 0 && <SourcesList sources={sources} />}
  </article>

  <a href={backLinks[type].href} class="back-link">&larr; {backLinks[type].label}</a>
</BaseLayout>
