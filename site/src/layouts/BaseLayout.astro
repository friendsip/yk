---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  wide?: boolean;
  /** OpenGraph type — 'article' for content pages, defaults to 'website' */
  ogType?: 'website' | 'article';
  /** Absolute or site-relative path to a social sharing image */
  image?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
}

const {
  title,
  description,
  wide = false,
  ogType = 'website',
  image = '/og-default.png',
  publishedTime,
  modifiedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const fullTitle = `${title} | YourKids`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="YourKids" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- OpenGraph -->
    <meta property="og:site_name" content="YourKids" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Fonts: preconnect + non-blocking stylesheet (was a render-blocking CSS @import) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700&family=Nunito+Sans:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    />

    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main class={`page-container${wide ? ' page-container--wide' : ''}`}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
