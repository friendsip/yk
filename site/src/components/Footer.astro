---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const sections = [
  { href: '/baby', label: 'Baby week by week' },
  { href: '/toddler', label: 'Toddler guide' },
  { href: '/tools', label: 'Tools & calculators' },
  { href: '/games', label: 'Educational games' },
  { href: '/articles', label: 'Articles' },
  { href: '/curated', label: 'Curated Links' },
  { href: '/editorial', label: 'Editorials' },
  { href: '/topics', label: 'Topics' },
  { href: '/recommended', label: 'Recommended' },
  { href: '/deals', label: 'Deals' },
  { href: '/sites', label: 'Trusted Sites' },
];
---

<footer class="site-footer">
  <div class="site-footer__columns">
    <div class="site-footer__about">
      <Logo />
      <p>
        We gather the most helpful parenting articles, guides, and links we
        can find — carefully sourced, updated weekly, and honest about what
        we don't know.
      </p>
    </div>

    <nav class="site-footer__links" aria-label="Footer">
      <p class="site-footer__heading">Explore</p>
      <ul>
        {sections.map(({ href, label }) => (
          <li><a href={href}>{label}</a></li>
        ))}
        <li><a href="/rss.xml">RSS feed</a></li>
      </ul>
    </nav>

    <div class="site-footer__newsletter">
      <p class="site-footer__heading">Weekly digest</p>
      <p>
        A short, friendly email every Sunday with the week's best new guides
        and links. <span class="coming-soon-pill">Coming soon</span>
      </p>
    </div>
  </div>

  <div class="site-footer__legal">
    <p>&copy; {year} YourKids. Curated with care for parents.</p>
    <p class="site-footer__legal-links">
      <a href="/privacy">Privacy</a>
    </p>
  </div>
</footer>
