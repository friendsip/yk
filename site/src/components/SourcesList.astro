---
interface Props {
  sources: string[];
}

const { sources } = Astro.props;

function domainFromUrl(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
}
---

{sources.length > 0 && (
  <div class="sources-list">
    <p class="sources-list__heading">Sources</p>
    <ul>
      {sources.map((source) => (
        <li>
          <a href={source} target="_blank" rel="noopener noreferrer">{domainFromUrl(source)}</a>
        </li>
      ))}
    </ul>
  </div>
)}
