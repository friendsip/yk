---
import TypeBadge from './TypeBadge.astro';
import TagList from './TagList.astro';
import { artForTags } from '../lib/topicArt';

interface Props {
  title: string;
  summary: string;
  type: 'evergreen' | 'curated' | 'editorial';
  tags: string[];
  date: Date;
  href: string;
  /** Large layout for the homepage featured slot */
  featured?: boolean;
}

const { title, summary, type, tags, date, href, featured = false } = Astro.props;

const art = artForTags(tags);

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<div
  class={`content-card${featured ? ' content-card--featured' : ''}`}
  style={`--accent: ${art.accent}; --accent-tint: ${art.tint};`}
>
  <div class="content-card__art" aria-hidden="true" set:html={art.svg} />
  <div class="content-card__body">
    <div class="content-card__meta">
      <TypeBadge type={type} />
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <h3 class="content-card__title">
      <a href={href} class="content-card__link">{title}</a>
    </h3>
    <p class="content-card__summary">{summary}</p>
    <div class="content-card__tags">
      <TagList tags={tags} />
    </div>
  </div>
</div>
