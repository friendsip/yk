---
import TypeBadge from './TypeBadge.astro';
import TagList from './TagList.astro';

interface Props {
  title: string;
  summary: string;
  type: 'evergreen' | 'curated' | 'editorial';
  tags: string[];
  date: Date;
  href: string;
}

const { title, summary, type, tags, date, href } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<div class="content-card">
  <div class="content-card__meta">
    <TypeBadge type={type} />
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <h3 class="content-card__title">
    <a href={href} class="content-card__link">{title}</a>
  </h3>
  <p class="content-card__summary">{summary}</p>
  <div class="content-card__tags">
    <TagList tags={tags} />
  </div>
</div>
