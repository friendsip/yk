---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { artForTag, defaultArt } from '../lib/topicArt';

const allContent = await getCollection('content');
const sorted = allContent.sort(
  (a, b) => b.data.first_published.valueOf() - a.data.first_published.valueOf()
);

const [featured, ...rest] = sorted;
const latest = rest.slice(0, 6);
const curatedLinks = sorted.filter(c => c.data.type === 'curated').slice(0, 3);

// Build tag counts from all content
const tagCounts = new Map<string, number>();
for (const item of allContent) {
  for (const tag of item.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const topics = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([tag, count]) => ({ tag, count }));

function toDisplayName(tag: string): string {
  return tag.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

function hrefForItem(item: { slug: string; data: { type: string } }): string {
  const typeRoutes: Record<string, string> = {
    evergreen: '/articles/',
    curated: '/curated/',
    editorial: '/editorial/',
  };
  return (typeRoutes[item.data.type] || '/articles/') + item.slug;
}
---

<BaseLayout title="Home" description="Parenting is hard. Finding good advice shouldn't be. Every week we gather the most helpful articles, guides, and links we can find — carefully sourced and never judgemental." wide>
  <section class="home-hero">
    <div class="home-hero__text">
      <h1>Parenting is hard. Finding good advice shouldn't be.</h1>
      <p>
        Every week we gather the most helpful articles, guides, and links we
        can find — carefully sourced, never judgemental, and honest about the
        things nobody knows for sure.
      </p>
      <div class="home-hero__actions">
        <a href="/topics" class="button button--primary">Browse by topic</a>
        <a href="/articles" class="button button--ghost">Latest articles</a>
      </div>
      <p class="home-hero__newsletter">
        A friendly weekly email is on its way <span class="coming-soon-pill">Coming soon</span>
      </p>
    </div>
    <div class="home-hero__art" aria-hidden="true">
      <svg viewBox="0 0 280 200" xmlns="http://www.w3.org/2000/svg" fill="none">
        <!-- sun -->
        <circle cx="226" cy="44" r="26" fill="#e8b84b"/>
        <!-- clouds -->
        <ellipse cx="60" cy="38" rx="28" ry="11" fill="#f5f0ea"/>
        <ellipse cx="86" cy="46" rx="22" ry="9" fill="#f0ece6"/>
        <!-- paper boat -->
        <path d="M140 52 L140 118 L192 118 Z" fill="#e07856"/>
        <path d="M140 64 L140 118 L104 118 Z" fill="#c17f2e"/>
        <path d="M76 128 L212 128 L186 158 L102 158 Z" fill="#5b7a5e"/>
        <!-- waves -->
        <path d="M28 172 Q48 162 68 172 T108 172 T148 172 T188 172 T228 172 T262 172" stroke="#7da8c3" stroke-width="7" stroke-linecap="round"/>
        <path d="M48 190 Q68 182 88 190 T128 190 T168 190 T208 190 T244 190" stroke="#a7c4d6" stroke-width="5" stroke-linecap="round"/>
        <!-- sprout on deck -->
        <circle cx="144" cy="120" r="6" fill="#e8b84b"/>
      </svg>
    </div>
  </section>

  {featured && (
    <section class="home-section fade-up">
      <div class="section-heading">
        <h2>Featured</h2>
      </div>
      <ContentCard
        title={featured.data.title}
        summary={featured.data.summary}
        type={featured.data.type}
        tags={featured.data.tags}
        date={featured.data.first_published}
        href={hrefForItem(featured)}
        featured
      />
    </section>
  )}

  {latest.length > 0 && (
    <section class="home-section fade-up">
      <div class="section-heading">
        <h2>Latest</h2>
        <a href="/articles">All articles &rarr;</a>
      </div>
      <div class="content-grid">
        {latest.map((item) => (
          <ContentCard
            title={item.data.title}
            summary={item.data.summary}
            type={item.data.type}
            tags={item.data.tags}
            date={item.data.first_published}
            href={hrefForItem(item)}
          />
        ))}
      </div>
    </section>
  )}

  {topics.length > 0 && (
    <section class="home-section fade-up">
      <div class="section-heading">
        <h2>Browse by Topic</h2>
        <a href="/topics">All topics &rarr;</a>
      </div>
      <div class="topic-grid">
        {topics.map(({ tag, count }) => {
          const art = artForTag(tag);
          return (
            <a href={`/topics/${tag}`} class="topic-card" style={`--accent: ${art.accent}; --accent-tint: ${art.tint};`}>
              <span class="topic-card__art" aria-hidden="true" set:html={art.svg} />
              <span class="topic-card__name">{toDisplayName(tag)}</span>
              <span class="topic-card__count">{count} {count === 1 ? 'article' : 'articles'}</span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {curatedLinks.length > 0 && (
    <section class="home-section fade-up">
      <div class="section-heading">
        <h2>Curated Links</h2>
        <a href="/curated">All curated links &rarr;</a>
      </div>
      <div class="content-grid">
        {curatedLinks.map((item) => (
          <ContentCard
            title={item.data.title}
            summary={item.data.summary}
            type={item.data.type}
            tags={item.data.tags}
            date={item.data.first_published}
            href={hrefForItem(item)}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
