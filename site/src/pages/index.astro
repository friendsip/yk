---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';

const allContent = await getCollection('content');
const sorted = allContent.sort(
  (a, b) => b.data.first_published.valueOf() - a.data.first_published.valueOf()
);

// "Featured this week": pinned articles first, then newest — exactly three,
// never duplicated elsewhere on the page (brief §1).
const featuredItems = sorted.filter(c => c.data.featured);
const restItems = sorted.filter(c => !c.data.featured);
const featured = [...featuredItems, ...restItems].slice(0, 3);

// Topic tiles: top six tags by article count, tint rotation coral → teal → sand
const tagCounts = new Map<string, number>();
for (const item of allContent) {
  for (const tag of item.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const topics = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([tag, count]) => ({ tag, count }));

const tints = ['coral', 'teal', 'sand'];

function toDisplayName(tag: string): string {
  return tag.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

function hrefForItem(item: { slug: string; data: { type: string } }): string {
  const typeRoutes: Record<string, string> = {
    evergreen: '/articles/',
    curated: '/curated/',
    editorial: '/editorial/',
  };
  return (typeRoutes[item.data.type] || '/articles/') + item.slug;
}
---

<BaseLayout title="Home" description="Parenting is hard, but there's plenty of joy to find. Every week we gather the most helpful articles, guides, and links we can find — carefully sourced and never judgemental." wide>
  <section class="hero">
    <div class="hero-copy">
      <span class="hero-badge">Updated every week</span>
      <h1>Parenting is hard, but there's plenty of joy to find.<br />Let's explore together</h1>
      <p>
        The most helpful articles, guides, and links we can find — carefully
        sourced, never judgemental, and honest about the things nobody knows
        for sure.
      </p>
      <div class="hero-ctas">
        <a class="btn btn-teal" href="/topics">Browse by topic</a>
        <a class="btn btn-outline" href="/articles">Latest articles</a>
      </div>
    </div>
    <div class="hero-art-wrap">
      <div class="hero-art">
        <img
          src="/images/hero-jonathan-borba.jpg"
          alt="Smiling mother holding her laughing baby"
          width="420"
          height="300"
          fetchpriority="high"
        />
      </div>
      <p class="photo-credit">
        Photo by <a href="https://unsplash.com/@jonathanborba?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">Jonathan Borba</a>
        on <a href="https://unsplash.com/photos/smiling-woman-carrying-baby-RWgE9_lKj_Y?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">Unsplash</a>
      </p>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="home-section fade-up">
      <div class="section-heading">
        <h2>Featured this week</h2>
        <a href="/articles">All articles &rarr;</a>
      </div>
      <div class="content-grid">
        {featured.map((item) => (
          <ContentCard
            title={item.data.title}
            summary={item.data.summary}
            type={item.data.type}
            tags={item.data.tags}
            image={item.data.image}
            imageAlt={item.data.image_alt}
            date={item.data.first_published}
            href={hrefForItem(item)}
          />
        ))}
      </div>
    </section>
  )}

  {topics.length > 0 && (
    <section class="home-section fade-up">
      <div class="section-heading">
        <h2>Browse by topic</h2>
        <a href="/topics">All topics &rarr;</a>
      </div>
      <div class="tile-grid">
        {topics.map(({ tag, count }, i) => (
          <a class={`tile tile-${tints[i % 3]}`} href={`/topics/${tag}`}>
            <b>{toDisplayName(tag)}</b>
            <span>{count} {count === 1 ? 'article' : 'articles'}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="newsletter-band fade-up" id="newsletter">
    <div class="newsletter-band__copy">
      <h2>A short, friendly email every Sunday</h2>
      <p>The week's best new guides and links. No judgement, no spam, unsubscribe anytime.</p>
    </div>
    <form class="newsletter-band__form" action="/subscribe" method="post">
      <label class="sr-only" for="newsletter-email">Email address</label>
      <input id="newsletter-email" type="email" name="email" placeholder="you@example.com" required />
      <button class="btn btn-coral" type="submit">Sign up</button>
    </form>
    <p class="newsletter-band__soon" hidden>
      Nearly there — the first weekly email is being prepared, and signups
      open with it very soon. Thank you for wanting in! 💛
    </p>
  </section>
</BaseLayout>

<script>
  // The email service isn't wired up yet (see docs/next-tasks.md §6) — be
  // honest on submit rather than posting into the void.
  const band = document.getElementById('newsletter');
  const form = band?.querySelector('form');
  const soon = band?.querySelector('.newsletter-band__soon') as HTMLElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    (form as HTMLElement).hidden = true;
    if (soon) soon.hidden = false;
  });
</script>
