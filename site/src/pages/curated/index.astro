---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import SectionHero from '../../components/SectionHero.astro';
import { sectionArt } from '../../lib/topicArt';

const curated = (await getCollection('content'))
  .filter(c => c.data.type === 'curated')
  .sort((a, b) => b.data.first_published.valueOf() - a.data.first_published.valueOf());
---

<BaseLayout title="Curated Links" description="Hand-picked links to quality parenting content from around the web." wide>
  <SectionHero title="Curated Links" blurb="Hand-picked links to quality parenting content from around the web." art={sectionArt.curated} />

  {curated.length === 0 ? (
    <p class="empty-state">No curated links yet. Check back soon.</p>
  ) : (
    <div class="content-grid">
      {curated.map((item) => (
        <ContentCard
          title={item.data.title}
          summary={item.data.summary}
          type={item.data.type}
          tags={item.data.tags}
          date={item.data.first_published}
          href={`/curated/${item.slug}`}
        />
      ))}
    </div>
  )}
</BaseLayout>
