---
import BaseLayout from '../layouts/BaseLayout.astro';

// Search is powered by Pagefind, which indexes the built site. The /pagefind/
// assets are generated by `pagefind --site dist` during `npm run build`, so
// search works in `npm run preview` and in production — but NOT in `astro dev`
// (the index doesn't exist yet there). That's expected.
---

<BaseLayout
  title="Search"
  description="Search yourkids.com's articles, guides, and curated links."
>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" slot="head" />

  <div class="search-page">
    <h1>Search</h1>
    <p class="search-page__intro">
      Looking for something in particular? Search our articles, guides, and
      curated links below.
    </p>
    <div id="search" class="search-page__box"></div>
    <noscript>
      <p>Search needs JavaScript. You can also <a href="/topics">browse by topic</a>.</p>
    </noscript>
  </div>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
        });
      }
    });
  </script>
</BaseLayout>
