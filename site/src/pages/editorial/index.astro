---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import SectionHero from '../../components/SectionHero.astro';
import { sectionArt } from '../../lib/topicArt';

const editorials = (await getCollection('content'))
  .filter(c => c.data.type === 'editorial')
  .sort((a, b) => b.data.first_published.valueOf() - a.data.first_published.valueOf());
---

<BaseLayout title="Editorials" description="Editor's perspectives on parenting topics." wide>
  <SectionHero title="Editorials" blurb="Our honest take on tricky topics — clearly labelled as perspective, not gospel." art={sectionArt.editorial} />

  {editorials.length === 0 ? (
    <p class="empty-state">No editorials yet. Check back soon.</p>
  ) : (
    <div class="content-grid">
      {editorials.map((item) => (
        <ContentCard
          title={item.data.title}
          summary={item.data.summary}
          type={item.data.type}
          tags={item.data.tags}
          date={item.data.first_published}
          href={`/editorial/${item.slug}`}
        />
      ))}
    </div>
  )}
</BaseLayout>
