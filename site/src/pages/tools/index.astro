---
/**
 * "Our free apps" — the launcher. A phone-home-screen-style grid of every
 * app and tool. Linked from the main site nav; each app opens in the same
 * design world (see ToolAppLayout).
 */
import ToolAppLayout from '../../layouts/ToolAppLayout.astro';

const tiles = [
  {
    href: '/app',
    name: 'Baby & Toddler',
    sub: 'daily companion',
    emoji: null, // uses the app icon image
    bg: '#ffffff',
  },
  {
    href: '/tools/activities',
    name: 'What can we do today?',
    sub: 'spin the wheel',
    emoji: '🎡',
    bg: 'linear-gradient(135deg, #fce4d8, #f6d9f0)',
  },
  {
    href: 'https://games.yourkids.com',
    name: 'What the Word?!',
    sub: 'team word game',
    emoji: '💬',
    bg: 'linear-gradient(135deg, #fbe3d4, #dff3ee)',
  },
  {
    href: 'https://farm.yourkids.com',
    name: 'Working at the Farm',
    sub: '3D game for littles',
    emoji: '🚜',
    bg: 'linear-gradient(135deg, #fff3d9, #dff3ee)',
  },
  {
    href: '/tools/childcare',
    name: 'Childcare costs',
    sub: 'funding & prices',
    emoji: '💷',
    bg: 'linear-gradient(135deg, #dff3ee, #d8ecfb)',
  },
  {
    href: '/tools/vaccinations',
    name: 'Vaccination planner',
    sub: 'dates & reminders',
    emoji: '💉',
    bg: 'linear-gradient(135deg, #e6e0f7, #d8ecfb)',
  },
  {
    href: '/tools/baby-age',
    name: 'Baby age',
    sub: 'weeks & corrected age',
    emoji: '🎂',
    bg: 'linear-gradient(135deg, #fff3d9, #fce4d8)',
  },
  {
    href: '/tools/nap-schedule',
    name: 'Naps & wake windows',
    sub: 'birth to three',
    emoji: '😴',
    bg: 'linear-gradient(135deg, #d8ecfb, #e6e0f7)',
  },
  {
    href: '/tools/checklists',
    name: 'Checklists',
    sub: 'tick off & print',
    emoji: '✅',
    bg: 'linear-gradient(135deg, #dff3ee, #fff3d9)',
  },
  {
    href: '/baby',
    name: 'Baby week by week',
    sub: 'the full guide',
    emoji: '👶',
    bg: 'linear-gradient(135deg, #fce4d8, #fff3d9)',
  },
  {
    href: '/toddler',
    name: 'Toddler guide',
    sub: 'one to three',
    emoji: '🧒',
    bg: 'linear-gradient(135deg, #f6d9f0, #fce4d8)',
  },
  {
    href: '/games',
    name: 'Educational games',
    sub: 'groups & classrooms',
    emoji: '🎲',
    bg: 'linear-gradient(135deg, #e6e0f7, #dff3ee)',
  },
];
---

<ToolAppLayout
  title="Our free apps"
  description="Every free app and tool on yourkids.com — the Baby & Toddler daily companion, the activity wheel, childcare costs and funding, NHS vaccination planner, guides, checklists and more. No accounts, no ads, no cost."
  heading="Our free apps"
  sub="Everything here is genuinely free — no accounts, no ads, no paywalls. Built for tired parents, with love."
  backHref="/"
  backLabel="yourkids.com"
>
  <div class="launcher">
    {tiles.map((tile) => (
      <a class="launcher-tile" href={tile.href}>
        <span class="launcher-tile__icon" style={`--tile-bg: ${tile.bg};`}>
          {tile.emoji ? tile.emoji : <img src="/app/icon.svg" alt="" width="76" height="76" />}
        </span>
        <span class="launcher-tile__name">{tile.name}</span>
        <span class="launcher-tile__sub">{tile.sub}</span>
      </a>
    ))}
  </div>
</ToolAppLayout>
