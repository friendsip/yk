---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { sectionArt } from '../../lib/topicArt';

const art = sectionArt.tools;

const tools = [
  {
    href: '/tools/activities',
    label: '🎡 What can we do today?',
    blurb: 'Stuck for ideas? Spin the wheel: hundreds of free activities for toddlers to teens, indoors and out — a new one every day.',
  },
  {
    href: '/tools/childcare',
    label: 'Childcare costs & funding',
    blurb: "What childcare costs near you, what government help you can get, and exactly when it starts — worked out from your child's birthday.",
  },
  {
    href: '/tools/vaccinations',
    label: 'Vaccination planner',
    blurb: "Your baby's NHS vaccination timeline, with real dates from their date of birth — and a calendar file to download.",
  },
  {
    href: '/tools/baby-age',
    label: 'Baby age calculator',
    blurb: 'How many weeks (or months, or days) old is my baby? Includes corrected age for premature babies.',
  },
  {
    href: '/tools/nap-schedule',
    label: 'Naps & wake windows',
    blurb: 'Typical wake windows, naps and total sleep by age, from birth to three — ranges, not rules.',
  },
  {
    href: '/tools/checklists',
    label: 'Checklists',
    blurb: 'Hospital bag, newborn essentials, travelling with a baby, starting school — tick things off, then print them.',
  },
  {
    href: '/baby',
    label: 'Baby week by week',
    blurb: "What to expect from your baby, week by week from birth — what's normal, what's worth checking, and honest feeding help.",
  },
  {
    href: '/toddler',
    label: 'Toddler guide',
    blurb: 'One to three, stage by stage — what to expect, how to help them grow, and games that won’t wear you out.',
  },
  {
    href: '/games',
    label: 'Educational games',
    blurb: 'Original games for classrooms, playgroups and family gatherings — coming soon.',
  },
];
---

<BaseLayout
  title="Our free apps"
  description="Every free app and tool on yourkids.com — the Baby & Toddler daily companion, childcare costs and funding, NHS vaccination planner, week-by-week guides, checklists and more. No accounts, no ads, no cost."
>
  <SectionHero
    title="Our free apps"
    blurb="Everything here is genuinely free — no accounts to make, no ads, no paywalls, and anything you enter stays on your device. Built for tired parents, with love."
    art={art}
  />

  <a class="app-promo" href="/app">
    <img src="/app/icon.svg" alt="" width="52" height="52" />
    <span class="app-promo__text">
      <strong>The Baby & Toddler app</strong> — a loving daily companion for
      your baby's and toddler's first years. What to expect today, gentle
      hints, little celebrations.
    </span>
    <span class="app-promo__cta">Open &rarr;</span>
  </a>

  <div class="stage-grid stage-grid--wide guide-section" style={`--accent:${art.accent}; --accent-tint:${art.tint};`}>
    {tools.map((t) => (
      <a class="stage-card" href={t.href}>
        <span class="stage-card__label">{t.label}</span>
        <span class="stage-card__title">{t.blurb}</span>
      </a>
    ))}
  </div>
</BaseLayout>
