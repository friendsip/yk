---
import ToolAppLayout from '../../layouts/ToolAppLayout.astro';
import GuideDisclaimer from '../../components/GuideDisclaimer.astro';
import { babyWeeks } from '../../data/baby/weeks';
import { babyMonths } from '../../data/baby/months';
import { toddlerStages } from '../../data/toddler/stages';

const stageRanges = [
  ...[...babyWeeks, ...babyMonths].map((s) => ({
    id: s.id,
    label: s.label,
    from: s.ageWeeksFrom,
    to: s.ageWeeksTo,
    kind: 'baby',
  })),
  ...toddlerStages.map((s) => ({
    id: s.id,
    label: s.label,
    from: s.ageWeeksFrom,
    to: s.ageWeeksTo,
    kind: 'toddler',
  })),
];
---

<ToolAppLayout
  title="Baby age calculator — weeks, months and corrected age"
  description="How many weeks old is my baby? Work out your baby's exact age in weeks, months and days — including corrected (adjusted) age for premature babies."
  heading="Baby age 🎂"
  sub="Weeks? Months? Both at once, somehow? Get their exact age — and corrected age if they arrived early."
>
  <div
    class="tool-card"
    id="age-tool"
    data-stages={JSON.stringify(stageRanges)}
  >
    <h2>Your baby</h2>
    <div class="tool-form">
      <div class="tool-field">
        <label for="age-dob">Date of birth</label>
        <input type="date" id="age-dob" />
      </div>
      <div class="tool-field--checkbox tool-field">
        <input type="checkbox" id="age-early" />
        <label for="age-early">Born earlier than expected (3+ weeks early)</label>
      </div>
      <div class="tool-field" id="age-due-field" hidden>
        <label for="age-due">Original due date</label>
        <input type="date" id="age-due" />
      </div>
    </div>
  </div>

  <div class="tool-result" id="age-result" hidden>
    <h2>Right now</h2>
    <p class="tool-result__big" id="age-headline"></p>
    <p class="tool-result__sub" id="age-detail"></p>
    <div id="age-corrected" hidden>
      <h3>Corrected age</h3>
      <p class="tool-result__big" id="age-corrected-headline"></p>
      <p class="tool-result__sub">
        Corrected (adjusted) age counts from the due date instead of the birth
        date. For babies born early, milestones usually follow corrected age —
        health professionals generally use it until around two years old.
      </p>
    </div>
    <p id="age-links"></p>
  </div>

  <GuideDisclaimer />
</ToolAppLayout>

<script>
  import { daysSince, ageHeadline, ageBreakdown, todayLocalISO } from '../../lib/dates';
  import { loadFirst, BABY_BIRTH_KEY, TODDLER_BIRTH_KEY } from '../../lib/storage';

  const tool = document.getElementById('age-tool') as HTMLElement;
  const stages: { id: string; label: string; from: number; to: number; kind: string }[] =
    JSON.parse(tool.dataset.stages || '[]');

  const dobInput = document.getElementById('age-dob') as HTMLInputElement;
  const earlyBox = document.getElementById('age-early') as HTMLInputElement;
  const dueField = document.getElementById('age-due-field') as HTMLElement;
  const dueInput = document.getElementById('age-due') as HTMLInputElement;
  const result = document.getElementById('age-result') as HTMLElement;

  dobInput.max = todayLocalISO();

  // Reuse the date the guides/app may already know
  const saved = loadFirst(BABY_BIRTH_KEY, TODDLER_BIRTH_KEY);
  if (saved) dobInput.value = saved;

  function render() {
    const days = daysSince(dobInput.value);
    if (days === null) {
      result.hidden = true;
      return;
    }

    (document.getElementById('age-headline') as HTMLElement).textContent = ageHeadline(days);
    (document.getElementById('age-detail') as HTMLElement).textContent = ageBreakdown(days);

    // Corrected age
    const correctedBlock = document.getElementById('age-corrected') as HTMLElement;
    let guideDays = days;
    if (earlyBox.checked && dueInput.value) {
      const correctedDays = daysSince(dueInput.value); // null = due date not yet reached
      if (correctedDays !== null && correctedDays < days) {
        (document.getElementById('age-corrected-headline') as HTMLElement).textContent =
          `${ageHeadline(correctedDays)} (corrected)`;
        correctedBlock.hidden = false;
        guideDays = correctedDays;
      } else if (correctedDays === null) {
        (document.getElementById('age-corrected-headline') as HTMLElement).textContent =
          "Not due yet — corrected age starts from the due date.";
        correctedBlock.hidden = false;
        guideDays = 0;
      } else {
        correctedBlock.hidden = true;
      }
    } else {
      correctedBlock.hidden = true;
    }

    // Link to the right guide (by corrected age where relevant)
    const weeks = Math.floor(guideDays / 7);
    const stage = stages.find((s) => weeks >= s.from && weeks <= s.to);
    const links = document.getElementById('age-links') as HTMLElement;
    if (stage) {
      links.innerHTML = `Read what's typical right now in <a href="/${stage.kind === 'baby' ? 'baby' : 'toddler'}/${stage.id}">${stage.label}</a> — or open <a href="/app">the app</a> for a daily companion.`;
    } else {
      links.innerHTML = `Our <a href="/topics">guides</a> carry on from here — or open <a href="/app">the app</a>.`;
    }

    result.hidden = false;
  }

  earlyBox.addEventListener('change', () => {
    dueField.hidden = !earlyBox.checked;
    render();
  });
  dobInput.addEventListener('input', render);
  dueInput.addEventListener('input', render);
  render();
</script>
