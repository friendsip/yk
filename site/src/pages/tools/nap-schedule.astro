---
import ToolAppLayout from '../../layouts/ToolAppLayout.astro';
import GuideDisclaimer from '../../components/GuideDisclaimer.astro';
import { wakeWindowBands, wakeWindowIntro, wakeWindowSources } from '../../data/tools/wakeWindows';

const ranges = wakeWindowBands.map((b) => ({ id: b.id, from: b.fromWeeks, to: b.toWeeks }));
---

<ToolAppLayout
  title="Naps and wake windows by age — birth to three"
  description="Typical wake windows, naps per day and total sleep for babies and toddlers, from newborn to three years — presented as honest ranges, not rules."
  heading="Naps & wake windows 😴"
  sub="How long can they comfortably stay awake? Ranges, not rules — your baby's cues always win."
>
  <div class="stage-page">
    <section class="stage-section">
      {wakeWindowIntro.map((p) => <p>{p}</p>)}
    </section>

    <div class="tool-card" id="nap-tool" data-ranges={JSON.stringify(ranges)}>
      <h2>Jump to your baby's age</h2>
      <div class="tool-form">
        <div class="tool-field">
          <label for="nap-dob">Date of birth (optional)</label>
          <input type="date" id="nap-dob" />
        </div>
      </div>
      <p class="tool-note">We'll highlight the right row below.</p>
    </div>

    <table class="tool-table">
      <thead>
        <tr>
          <th scope="col">Age</th>
          <th scope="col">Wake window</th>
          <th scope="col">Naps/day</th>
          <th scope="col">Total sleep (24h)</th>
        </tr>
      </thead>
      <tbody>
        {wakeWindowBands.map((band) => (
          <tr id={`band-${band.id}`}>
            <td>{band.ageLabel}</td>
            <td>{band.wakeWindow}</td>
            <td>{band.napsPerDay}</td>
            <td>{band.totalSleep24h}</td>
          </tr>
        ))}
      </tbody>
    </table>

    {wakeWindowBands.map((band) => (
      <section class="stage-section" id={`notes-${band.id}`}>
        <h2>{band.ageLabel}</h2>
        <ul>
          {band.notes.map((n) => <li>{n}</li>)}
        </ul>
      </section>
    ))}

    <GuideDisclaimer />

    <footer class="stage-sources">
      <h2>Sources</h2>
      <ul>
        {wakeWindowSources.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a>
            {' '}— {s.org} <span class="stage-sources__region">({s.region})</span>
          </li>
        ))}
      </ul>
    </footer>
  </div>
</ToolAppLayout>

<script>
  import { completedWeeks, todayLocalISO } from '../../lib/dates';
  import { loadFirst, BABY_BIRTH_KEY, TODDLER_BIRTH_KEY } from '../../lib/storage';

  const tool = document.getElementById('nap-tool') as HTMLElement;
  const ranges: { id: string; from: number; to: number }[] = JSON.parse(tool.dataset.ranges || '[]');
  const dob = document.getElementById('nap-dob') as HTMLInputElement;
  dob.max = todayLocalISO();

  const saved = loadFirst(BABY_BIRTH_KEY, TODDLER_BIRTH_KEY);
  if (saved) dob.value = saved;

  function highlight() {
    document.querySelectorAll('.tool-table tr.is-current').forEach((el) => el.classList.remove('is-current'));
    const weeks = completedWeeks(dob.value);
    if (weeks === null) return;
    const band = ranges.find((r) => weeks >= r.from && weeks <= r.to);
    if (band) {
      const row = document.getElementById(`band-${band.id}`);
      row?.classList.add('is-current');
      row?.scrollIntoView({ block: 'center', behavior: 'smooth' });
    }
  }

  dob.addEventListener('input', highlight);
  highlight();
</script>
