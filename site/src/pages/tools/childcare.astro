---
import ToolAppLayout from '../../layouts/ToolAppLayout.astro';
import GuideDisclaimer from '../../components/GuideDisclaimer.astro';
import {
  fundingSchemes,
  regionCosts,
  availabilityGuidance,
  childcareMeta,
  childcareSources,
} from '../../data/tools/childcare';

const clientData = {
  schemes: fundingSchemes,
  costs: regionCosts,
  meta: childcareMeta,
};
---

<ToolAppLayout
  title="Childcare costs & funding explorer (UK)"
  description="What childcare really costs in your part of the UK, what government funding you can get — funded hours, Tax-Free Childcare — and exactly when each starts, worked out from your child's birthday."
  heading="Childcare costs 💷"
  sub="What childcare costs near you, what help you can get, and exactly when it starts — worked out from your child's birthday."
>
  <div class="stage-page">
    <div class="tool-card">
      <h2>About your child &amp; childcare</h2>
      <p class="tool-card__hint">
        Expecting? Pop in the due date — this works just as well for planning
        ahead. Nothing you enter leaves your device.
      </p>
      <div class="tool-form">
        <div class="tool-field">
          <label for="cc-dob">Child's date of birth (or due date)</label>
          <input type="date" id="cc-dob" />
        </div>
        <div class="tool-field">
          <label for="cc-nation">Where you live</label>
          <select id="cc-nation">
            <option value="england">England</option>
            <option value="scotland">Scotland</option>
            <option value="wales">Wales</option>
            <option value="northern-ireland">Northern Ireland</option>
          </select>
        </div>
        <div class="tool-field" id="cc-region-field">
          <label for="cc-region">Your region</label>
          <select id="cc-region"></select>
        </div>
        <div class="tool-field">
          <label for="cc-provider">Type of childcare</label>
          <select id="cc-provider">
            <option value="nursery">Nursery</option>
            <option value="childminder">Childminder</option>
          </select>
        </div>
        <div class="tool-field">
          <label for="cc-hours">Hours you need</label>
          <select id="cc-hours">
            <option value="25">Part-time (about 25 hours/week)</option>
            <option value="50">Full-time (about 50 hours/week)</option>
          </select>
        </div>
        <div class="tool-field--checkbox tool-field">
          <input type="checkbox" id="cc-working" checked />
          <label for="cc-working">
            We meet the working-parent tests (each parent in work, earning at
            least the minimum threshold and under £100k a year)
          </label>
        </div>
        <div class="tool-field--checkbox tool-field">
          <input type="checkbox" id="cc-tfc" checked />
          <label for="cc-tfc">Include Tax-Free Childcare in the estimate (20% top-up)</label>
        </div>
      </div>
    </div>

    <div class="tool-result" id="cc-timeline-result" hidden>
      <h2>What you can get, and when</h2>
      <ol class="tool-timeline" id="cc-timeline"></ol>
      <p class="tool-note" id="cc-timeline-note"></p>
    </div>

    <div class="tool-result" id="cc-cost-result" hidden>
      <h2>What it might cost</h2>
      <div id="cc-costs"></div>
      <p class="tool-note">
        Estimates use typical {childcareMeta.costsSourceLabel} prices — your
        local providers set their own fees, and many charge extra for meals,
        nappies or consumables on funded hours. Treat this as a starting
        point, not a quote.
      </p>
    </div>

    <section class="stage-section">
      <h2>Finding childcare near you</h2>
      {availabilityGuidance.map((g) => (
        <>
          <h3>{g.heading}</h3>
          {g.paragraphs.map((p) => <p>{p}</p>)}
        </>
      ))}
    </section>

    <section class="stage-section">
      <h2>The small print</h2>
      <ul>
        {childcareMeta.notes.map((n) => <li>{n}</li>)}
      </ul>
      <p class="tool-note">Rates and rules as of {childcareMeta.ratesAsOf}.</p>
    </section>

    <GuideDisclaimer />

    <footer class="stage-sources">
      <h2>Sources</h2>
      <ul>
        {childcareSources.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a>
            {' '}— {s.org} <span class="stage-sources__region">({s.region})</span>
          </li>
        ))}
      </ul>
    </footer>
  </div>
</ToolAppLayout>

<script is:inline type="application/json" id="cc-data" set:html={JSON.stringify(clientData)} />

<script>
  import {
    computeEntitlements,
    estimateCost,
    type Scheme,
    type RegionCost,
  } from '../../lib/childcare';
  import { parseLocalDate as parseDate } from '../../lib/dates';
  import { loadFirst, BABY_BIRTH_KEY, TODDLER_BIRTH_KEY } from '../../lib/storage';

  const data = JSON.parse(document.getElementById('cc-data')!.textContent || '{}') as {
    schemes: Scheme[];
    costs: RegionCost[];
    meta: { ratesAsOf: string; costsSourceLabel: string; notes: string[] };
  };

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement & HTMLSelectElement;
  const dob = $('cc-dob');
  const nation = $('cc-nation');
  const region = $('cc-region');
  const provider = $('cc-provider');
  const hours = $('cc-hours');
  const working = $('cc-working');
  const tfc = $('cc-tfc');

  const esc = (t: string) => t.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const fmtDate = (d: Date) =>
    d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
  const money = (n: number) => `£${Math.round(n).toLocaleString('en-GB')}`;

  function populateRegions() {
    const isEngland = nation.value === 'england';
    const gbRow = (name: string) => data.costs.some((c) => c.region === name);
    let options: string[];
    if (isEngland) {
      options = data.costs
        .map((c) => c.region)
        .filter((r) => r !== 'Scotland' && r !== 'Wales' && r !== 'Northern Ireland');
    } else {
      const name = nation.options[nation.selectedIndex].text;
      options = gbRow(name) ? [name] : [];
    }
    region.innerHTML = options.map((r) => `<option>${esc(r)}</option>`).join('');
    (document.getElementById('cc-region-field') as HTMLElement).hidden = options.length <= 1;
  }

  function renderTimeline(birth: Date) {
    const list = computeEntitlements(data.schemes, birth, nation.value, working.checked).sort(
      (a, b) => (a.start?.getTime() ?? 0) - (b.start?.getTime() ?? 0)
    );
    (document.getElementById('cc-timeline') as HTMLElement).innerHTML = list
      .map(
        ({ scheme, started, label }) => `<li class="${started ? 'tool-timeline__past' : ''}">
          <p class="tool-timeline__when">${esc(scheme.name)} — ${esc(label)}</p>
          <div class="tool-timeline__what">
            ${scheme.summary.map((p) => `<p>${esc(p)}</p>`).join('')}
            <ul>${scheme.applyNotes.map((n) => `<li>${esc(n)}</li>`).join('')}</ul>
          </div>
        </li>`
      )
      .join('');
    (document.getElementById('cc-timeline-note') as HTMLElement).textContent = working.checked
      ? ''
      : "You've told us you don't meet the working-parent tests, so we've only shown support that doesn't depend on them.";
    (document.getElementById('cc-timeline-result') as HTMLElement).hidden = list.length === 0;
  }

  function renderCosts(birth: Date) {
    const holder = document.getElementById('cc-costs') as HTMLElement;
    const resultBox = document.getElementById('cc-cost-result') as HTMLElement;
    const row = data.costs.find((c) => c.region === region.value);
    if (!row) {
      holder.innerHTML =
        "<p>We don't have reliable typical prices for your area yet — your local Family Information Service will know current local rates.</p>";
      resultBox.hidden = false;
      return;
    }

    const wantHours = Number(hours.value) as 25 | 50;
    const entitlements = computeEntitlements(data.schemes, birth, nation.value, working.checked);
    const est = estimateCost({
      row,
      birthIso: dob.value,
      nation: nation.value,
      provider: provider.value as 'nursery' | 'childminder',
      wantHours,
      working: working.checked,
      tfc: tfc.checked,
      entitlements,
    });

    if (!est.ok) {
      holder.innerHTML =
        "<p>The survey doesn't publish a typical price for that combination in your region — your council's Family Information Service can tell you local rates.</p>";
      resultBox.hidden = false;
      return;
    }

    const grossLabel = est.englandFtBasis
      ? `roughly ${money(est.grossWeekly)}/week full price — the survey quotes full-time prices after 30 funded hours (${money(est.surveyFullTimeWeekly!)}/week), so we've added their value back for comparison`
      : `${money(est.grossWeekly)}/week before any help (${money(est.grossWeekly * 52)}/year)`;
    const childminderNote = est.childminderAgeTwo
      ? " (under-2 rate — age-2 childminder prices aren't published separately)"
      : '';
    const tfcNote = tfc.checked && working.checked
      ? ' Includes the Tax-Free Childcare 20% top-up (capped at £2,000/year per child).'
      : '';

    let html = `
      <p class="tool-result__sub">Typical ${esc(provider.value)} price in ${esc(region.value)} for ${wantHours} hours/week${childminderNote}:</p>
      <p class="tool-result__big">${est.englandFtBasis ? '' : money(est.grossWeekly) + '/week '}<span class="tool-result__sub">${esc(grossLabel)}</span></p>
      <h3>Your estimated cost now</h3>
      <p class="tool-result__big">${money(est.nowNetWeekly)}/week <span class="tool-result__sub">(about ${money(est.nowNetWeekly * 52)}/year)</span></p>
      <p class="tool-result__sub">${est.nowFundedHours > 0 ? `Includes ${est.nowFundedHours} funded hours/week (term-time, spread across the year).` : 'No funded hours yet at this age.'}${tfcNote}</p>
    `;

    if (est.future) {
      html += `
        <h3>From ${fmtDate(est.future.start)}</h3>
        <p class="tool-result__big">${money(est.future.netWeekly)}/week <span class="tool-result__sub">(about ${money(est.future.netWeekly * 52)}/year)</span></p>
        <p class="tool-result__sub">When ${esc(est.future.schemeName)} kicks in (${est.future.fundedHours} funded hours/week over ${est.future.weeksPerYear} weeks).</p>
      `;
    }

    if (est.sufficiencyNote) {
      html += `<p class="tool-result__sub" style="margin-top:1rem;"><strong>Availability where you are:</strong> ${esc(est.sufficiencyNote)}</p>`;
    }
    holder.innerHTML = html;
    resultBox.hidden = false;
  }

  function render() {
    const birth = parseDate(dob.value);
    if (!birth) {
      (document.getElementById('cc-timeline-result') as HTMLElement).hidden = true;
      (document.getElementById('cc-cost-result') as HTMLElement).hidden = true;
      return;
    }
    renderTimeline(birth);
    renderCosts(birth);
  }

  const saved = loadFirst(BABY_BIRTH_KEY, TODDLER_BIRTH_KEY);
  if (saved) dob.value = saved;

  nation.addEventListener('change', () => {
    populateRegions();
    render();
  });
  [dob, region, provider, hours, working, tfc].forEach((el) => el.addEventListener('input', render));
  populateRegions();
  render();
</script>
