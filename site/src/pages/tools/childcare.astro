---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import GuideDisclaimer from '../../components/GuideDisclaimer.astro';
import { sectionArt } from '../../lib/topicArt';
import {
  fundingSchemes,
  regionCosts,
  availabilityGuidance,
  childcareMeta,
  childcareSources,
} from '../../data/tools/childcare';

const art = sectionArt.tools;

const clientData = {
  schemes: fundingSchemes,
  costs: regionCosts,
  meta: childcareMeta,
};
---

<BaseLayout
  title="Childcare costs & funding explorer (UK)"
  description="What childcare really costs in your part of the UK, what government funding you can get — funded hours, Tax-Free Childcare — and exactly when each starts, worked out from your child's birthday."
>
  <SectionHero
    title="Childcare costs & funding"
    blurb="What childcare costs near you, what help the government gives, and — the part everyone finds baffling — exactly when it starts for your child. Worked out from their birthday."
    art={art}
  />

  <p class="stage-breadcrumb guide-breadcrumb"><a href="/tools">&larr; All tools</a></p>

  <div class="stage-page" style={`--accent:${art.accent}; --accent-tint:${art.tint};`}>
    <div class="tool-card">
      <h2>About your child &amp; childcare</h2>
      <p class="tool-card__hint">
        Expecting? Pop in the due date — this works just as well for planning
        ahead. Nothing you enter leaves your device.
      </p>
      <div class="tool-form">
        <div class="tool-field">
          <label for="cc-dob">Child's date of birth (or due date)</label>
          <input type="date" id="cc-dob" />
        </div>
        <div class="tool-field">
          <label for="cc-nation">Where you live</label>
          <select id="cc-nation">
            <option value="england">England</option>
            <option value="scotland">Scotland</option>
            <option value="wales">Wales</option>
            <option value="northern-ireland">Northern Ireland</option>
          </select>
        </div>
        <div class="tool-field" id="cc-region-field">
          <label for="cc-region">Your region</label>
          <select id="cc-region"></select>
        </div>
        <div class="tool-field">
          <label for="cc-provider">Type of childcare</label>
          <select id="cc-provider">
            <option value="nursery">Nursery</option>
            <option value="childminder">Childminder</option>
          </select>
        </div>
        <div class="tool-field">
          <label for="cc-hours">Hours you need</label>
          <select id="cc-hours">
            <option value="25">Part-time (about 25 hours/week)</option>
            <option value="50">Full-time (about 50 hours/week)</option>
          </select>
        </div>
        <div class="tool-field--checkbox tool-field">
          <input type="checkbox" id="cc-working" checked />
          <label for="cc-working">
            We meet the working-parent tests (each parent in work, earning at
            least the minimum threshold and under £100k a year)
          </label>
        </div>
        <div class="tool-field--checkbox tool-field">
          <input type="checkbox" id="cc-tfc" checked />
          <label for="cc-tfc">Include Tax-Free Childcare in the estimate (20% top-up)</label>
        </div>
      </div>
    </div>

    <div class="tool-result" id="cc-timeline-result" hidden>
      <h2>What you can get, and when</h2>
      <ol class="tool-timeline" id="cc-timeline"></ol>
      <p class="tool-note" id="cc-timeline-note"></p>
    </div>

    <div class="tool-result" id="cc-cost-result" hidden>
      <h2>What it might cost</h2>
      <div id="cc-costs"></div>
      <p class="tool-note">
        Estimates use typical {childcareMeta.costsSourceLabel} prices — your
        local providers set their own fees, and many charge extra for meals,
        nappies or consumables on funded hours. Treat this as a starting
        point, not a quote.
      </p>
    </div>

    <section class="stage-section">
      <h2>Finding childcare near you</h2>
      {availabilityGuidance.map((g) => (
        <>
          <h3>{g.heading}</h3>
          {g.paragraphs.map((p) => <p>{p}</p>)}
        </>
      ))}
    </section>

    <section class="stage-section">
      <h2>The small print</h2>
      <ul>
        {childcareMeta.notes.map((n) => <li>{n}</li>)}
      </ul>
      <p class="tool-note">Rates and rules as of {childcareMeta.ratesAsOf}.</p>
    </section>

    <GuideDisclaimer />

    <footer class="stage-sources">
      <h2>Sources</h2>
      <ul>
        {childcareSources.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a>
            {' '}— {s.org} <span class="stage-sources__region">({s.region})</span>
          </li>
        ))}
      </ul>
    </footer>
  </div>
</BaseLayout>

<script is:inline type="application/json" id="cc-data" set:html={JSON.stringify(clientData)} />

<script>
  interface Scheme {
    id: string;
    nation: string;
    name: string;
    summary: string[];
    eligibility: string[];
    ageFromMonths: number | null;
    termAfter: boolean;
    hoursPerWeek: number | null;
    weeksPerYear: number | null;
    applyNotes: string[];
    requiresWork?: boolean;
  }
  interface RegionCost {
    region: string;
    [key: string]: string | number | null;
  }

  const data = JSON.parse(document.getElementById('cc-data')!.textContent || '{}') as {
    schemes: Scheme[];
    costs: RegionCost[];
    meta: { ratesAsOf: string; costsSourceLabel: string; notes: string[] };
  };

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement & HTMLSelectElement;
  const dob = $('cc-dob');
  const nation = $('cc-nation');
  const region = $('cc-region');
  const provider = $('cc-provider');
  const hours = $('cc-hours');
  const working = $('cc-working');
  const tfc = $('cc-tfc');

  const requiresWork = (s: Scheme) => s.requiresWork === true;

  const esc = (t: string) =>
    t.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  const fmtDate = (d: Date) =>
    d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
  const money = (n: number) => `£${Math.round(n).toLocaleString('en-GB')}`;

  function addMonths(date: Date, months: number): Date {
    const r = new Date(date);
    const day = r.getDate();
    r.setMonth(r.getMonth() + months);
    if (r.getDate() < day) r.setDate(0);
    return r;
  }

  // English funded-hours terms start 1 September, 1 January and 1 April.
  function termStartAfter(date: Date): Date {
    const y = date.getFullYear();
    const boundaries = [
      new Date(y, 0, 1),
      new Date(y, 3, 1),
      new Date(y, 8, 1),
      new Date(y + 1, 0, 1),
    ];
    for (const b of boundaries) {
      if (b > date) return b;
    }
    return boundaries[3];
  }

  function populateRegions() {
    const isEngland = nation.value === 'england';
    const gbRow = (name: string) => data.costs.some((c) => c.region === name);
    let options: string[];
    if (isEngland) {
      options = data.costs
        .map((c) => c.region)
        .filter((r) => r !== 'Scotland' && r !== 'Wales' && r !== 'Northern Ireland');
    } else {
      const name = nation.options[nation.selectedIndex].text;
      options = gbRow(name) ? [name] : [];
    }
    region.innerHTML = options.map((r) => `<option>${esc(r)}</option>`).join('');
    (document.getElementById('cc-region-field') as HTMLElement).hidden = options.length <= 1;
  }

  interface Entitlement {
    scheme: Scheme;
    start: Date | null; // null = not age-based / already applies
    label: string;
  }

  function entitlements(birth: Date): Entitlement[] {
    const relevant = data.schemes.filter(
      (s) => (s.nation === nation.value || s.nation === 'uk-wide') && (!requiresWork(s) || working.checked)
    );
    return relevant.map((scheme) => {
      if (scheme.ageFromMonths === null) {
        return { scheme, start: null, label: 'Available now (if eligible)' };
      }
      const qualifying = addMonths(birth, scheme.ageFromMonths);
      const start = scheme.termAfter ? termStartAfter(qualifying) : qualifying;
      const label =
        start.getTime() <= Date.now()
          ? `Already available (since ${fmtDate(start)})`
          : `Starts ${fmtDate(start)}`;
      return { scheme, start, label };
    });
  }

  function renderTimeline(birth: Date) {
    const list = entitlements(birth).sort(
      (a, b) => (a.start?.getTime() ?? 0) - (b.start?.getTime() ?? 0)
    );
    const el = document.getElementById('cc-timeline') as HTMLElement;
    el.innerHTML = list
      .map(({ scheme, start, label }) => {
        const past = !start || start.getTime() <= Date.now();
        return `<li class="${past ? 'tool-timeline__past' : ''}">
          <p class="tool-timeline__when">${esc(scheme.name)} — ${esc(label)}</p>
          <div class="tool-timeline__what">
            ${scheme.summary.map((p) => `<p>${esc(p)}</p>`).join('')}
            <ul>${scheme.applyNotes.map((n) => `<li>${esc(n)}</li>`).join('')}</ul>
          </div>
        </li>`;
      })
      .join('');
    (document.getElementById('cc-timeline-note') as HTMLElement).textContent = working.checked
      ? ''
      : "You've told us you don't meet the working-parent tests, so we've only shown support that doesn't depend on them.";
    (document.getElementById('cc-timeline-result') as HTMLElement).hidden = list.length === 0;
  }

  function costKey(ageBand: string): string {
    if (provider.value === 'childminder') return 'childminderUnder2';
    return ageBand === 'under2' ? 'nurseryUnder2' : 'nurseryTwo';
  }

  function renderCosts(birth: Date) {
    const holder = document.getElementById('cc-costs') as HTMLElement;
    const resultBox = document.getElementById('cc-cost-result') as HTMLElement;
    const row = data.costs.find((c) => c.region === region.value);
    if (!row) {
      holder.innerHTML =
        "<p>We don't have reliable typical prices for your area yet — your local Family Information Service will know current local rates.</p>";
      resultBox.hidden = false;
      return;
    }

    const ageMonths = Math.max(
      0,
      (new Date().getFullYear() - birth.getFullYear()) * 12 + (new Date().getMonth() - birth.getMonth())
    );
    const ageBand = ageMonths < 24 ? 'under2' : 'two';
    const wantHours = Number(hours.value);
    const base = costKey(ageBand);
    const partTime = row[`${base}PartTime`] as number | null;
    const fullTime = row[`${base}FullTime`] as number | null;

    if (partTime == null && fullTime == null) {
      holder.innerHTML =
        "<p>The survey doesn't publish a typical price for that combination in your region — your council's Family Information Service can tell you local rates.</p>";
      resultBox.hidden = false;
      return;
    }

    // Survey basis differs by nation (see data file): England full-time
    // figures already have 30 funded hours deducted; part-time figures (and
    // all Scotland/Wales figures) are full price.
    const isEnglandFT = nation.value === 'england' && wantHours === 50;
    const hourly = partTime != null ? partTime / 25 : (fullTime as number) / 50;

    let gross: number;
    let grossLabel: string;
    if (isEnglandFT && fullTime != null && partTime != null) {
      gross = fullTime + 30 * (38 / 52) * hourly;
      grossLabel = `roughly ${money(gross)}/week full price — the survey quotes full-time prices after 30 funded hours (${money(fullTime)}/week), so we've added their value back for comparison`;
    } else {
      gross = ((wantHours === 50 ? fullTime : partTime) ?? (partTime as number) * 2) as number;
      grossLabel = `${money(gross)}/week before any help (${money(gross * 52)}/year)`;
    }

    const stretched = (s: Scheme) => (s.hoursPerWeek! * (s.weeksPerYear ?? 38)) / 52;
    const applyTfc = (cost: number) =>
      tfc.checked && working.checked ? cost - Math.min(cost * 0.2, 2000 / 52) : cost;

    const estimate = (fundedScheme: Scheme | null) => {
      // England eligible-for-30h full-timers: the survey figure IS the
      // after-funding price, so use it directly rather than re-deducting.
      if (isEnglandFT && fundedScheme?.hoursPerWeek === 30 && fullTime != null) {
        return { net: applyTfc(fullTime), funded: 30 };
      }
      // Otherwise start from the same gross shown above and deduct funded
      // hours at the marginal (part-time) hourly rate.
      const funded = fundedScheme ? Math.min(stretched(fundedScheme), wantHours) : 0;
      const cost = Math.max(0, gross - funded * hourly);
      return { net: applyTfc(cost), funded: fundedScheme?.hoursPerWeek ?? 0 };
    };

    const withHours = entitlements(birth).filter((e) => e.scheme.hoursPerWeek);
    const nowEnt =
      withHours
        .filter((e) => !e.start || e.start.getTime() <= Date.now())
        .sort((a, b) => b.scheme.hoursPerWeek! - a.scheme.hoursPerWeek!)[0] ?? null;
    const nextEnt =
      withHours
        .filter(
          (e) =>
            e.start &&
            e.start.getTime() > Date.now() &&
            e.scheme.hoursPerWeek! > (nowEnt?.scheme.hoursPerWeek ?? 0)
        )
        .sort((a, b) => a.start!.getTime() - b.start!.getTime())[0] ?? null;

    const nowEst = estimate(nowEnt?.scheme ?? null);
    const childminderNote =
      ageBand === 'two' && provider.value === 'childminder'
        ? " (under-2 rate — age-2 childminder prices aren't published separately)"
        : '';

    let html = `
      <p class="tool-result__sub">Typical ${esc(provider.value)} price in ${esc(region.value)} for ${wantHours} hours/week${childminderNote}:</p>
      <p class="tool-result__big">${isEnglandFT ? '' : money(gross) + '/week '}<span class="tool-result__sub">${esc(grossLabel)}</span></p>
      <h3>Your estimated cost now</h3>
      <p class="tool-result__big">${money(nowEst.net)}/week <span class="tool-result__sub">(about ${money(nowEst.net * 52)}/year)</span></p>
      <p class="tool-result__sub">${nowEst.funded > 0 ? `Includes ${nowEst.funded} funded hours/week (term-time, spread across the year).` : 'No funded hours yet at this age.'}${tfc.checked && working.checked ? ' Includes the Tax-Free Childcare 20% top-up (capped at £2,000/year per child).' : ''}</p>
    `;

    if (nextEnt) {
      const futureEst = estimate(nextEnt.scheme);
      html += `
        <h3>From ${fmtDate(nextEnt.start!)}</h3>
        <p class="tool-result__big">${money(futureEst.net)}/week <span class="tool-result__sub">(about ${money(futureEst.net * 52)}/year)</span></p>
        <p class="tool-result__sub">When ${esc(nextEnt.scheme.name)} kicks in (${nextEnt.scheme.hoursPerWeek} funded hours/week over ${nextEnt.scheme.weeksPerYear ?? 38} weeks).</p>
      `;
    }

    if (row.sufficiencyNote) {
      html += `<p class="tool-result__sub" style="margin-top:1rem;"><strong>Availability where you are:</strong> ${esc(String(row.sufficiencyNote))}</p>`;
    }
    holder.innerHTML = html;
    resultBox.hidden = false;
  }

  function render() {
    if (!dob.value) {
      (document.getElementById('cc-timeline-result') as HTMLElement).hidden = true;
      (document.getElementById('cc-cost-result') as HTMLElement).hidden = true;
      return;
    }
    const birth = new Date(`${dob.value}T00:00:00`);
    if (Number.isNaN(birth.getTime())) return;
    renderTimeline(birth);
    renderCosts(birth);
  }

  try {
    const saved = localStorage.getItem('yk-baby-birthdate') || localStorage.getItem('yk-toddler-birthdate');
    if (saved) dob.value = saved;
  } catch {}

  nation.addEventListener('change', () => {
    populateRegions();
    render();
  });
  [dob, region, provider, hours, working, tfc].forEach((el) =>
    el.addEventListener('input', render)
  );
  populateRegions();
  render();
</script>
