---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import { sectionArt, artForTag } from '../../lib/topicArt';

const allContent = await getCollection('content');

const tagCounts = new Map<string, number>();
for (const item of allContent) {
  for (const tag of item.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}

const topics = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([tag, count]) => ({ tag, count }));

function toDisplayName(tag: string): string {
  return tag.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<BaseLayout title="Topics" description="Browse parenting content by topic." wide>
  <SectionHero title="Topics" blurb="Find what you need, when you need it — everything we have, gathered by topic." art={sectionArt.topics} />

  {topics.length === 0 ? (
    <p class="empty-state">No topics yet.</p>
  ) : (
    <div class="topic-grid">
      {topics.map(({ tag, count }) => {
        const art = artForTag(tag);
        return (
          <a href={`/topics/${tag}`} class="topic-card" style={`--accent: ${art.accent}; --accent-tint: ${art.tint};`}>
            <span class="topic-card__art" aria-hidden="true" set:html={art.markup} />
            <span class="topic-card__name">{toDisplayName(tag)}</span>
            <span class="topic-card__count">{count} {count === 1 ? 'article' : 'articles'}</span>
          </a>
        );
      })}
    </div>
  )}
</BaseLayout>
